{
  "schema_version": 1,
  "package_name": "hello-world-macos",
  "runtime": "native-json",
  "entrypoint": "lib/libhello_world.dylib",
  "plugin": {
    "id": "hello-world",
    "name": "Hello World",
    "version": "0.1.0",
    "description": "The simplest runtime-loaded plugin in the playground.",
    "architecture": "native-json",
    "skill_level": "basic",
    "supported_hosts": [
      "cli",
      "tui",
      "egui",
      "iced",
      "dioxus",
      "web",
      "service"
    ],
    "capabilities": [
      {
        "key": "greeting",
        "description": "Returns a friendly greeting for any host surface."
      }
    ],
    "tags": [
      "starter",
      "native-plugin",
      "teaching"
    ],
    "actions": [
      {
        "id": "greet",
        "label": "Greet",
        "description": "Say hello to a supplied name.",
        "payload_hint": "{\"name\":\"Rustacean\"}"
      }
    ],
    "notes": [
      "This plugin is meant to be the first one you inspect in the repo.",
      "It demonstrates the JSON-over-FFI boundary with minimal complexity."
    ]
  },
  "artifacts": [
    {
      "path": "lib/libhello_world.dylib",
      "kind": "dynamic-library",
      "required": false
    },
    {
      "path": "plugin-manifest.json",
      "kind": "manifest-snapshot",
      "required": true
    },
    {
      "path": "release.json",
      "kind": "release-metadata",
      "required": true
    }
  ],
  "release": {
    "channel": "stable",
    "target": "x86_64-apple-darwin",
    "hosts": [
      "cli",
      "tui",
      "web",
      "service"
    ],
    "installer_hint": "Copy the dylib into a directory referenced by RUST_PLUGIN_SYSTEM_PLUGIN_DIR."
  }
}
